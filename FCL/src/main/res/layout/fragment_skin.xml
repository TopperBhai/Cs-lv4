<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/cs_bg"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="24dp">

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F21A1B2E"
            app:cardCornerRadius="28dp"
            app:cardElevation="16dp"
            app:strokeColor="#44FFB74D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:letterSpacing="0.15"
                    android:text="🎨  SKIN MANAGER"
                    android:textColor="#FFB74D"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Divider -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:background="#FFB74D" />

                <!-- ===== SKIN PREVIEW ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:strokeColor="#33FFB74D"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/skin_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"
                    android:text="Current Skin"
                    android:textColor="#4D78909C"
                    android:textSize="11sp" />

                <!-- ===== URL SECTION ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.1"
                    android:text="SKIN URL"
                    android:textColor="#78909C"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    app:cardBackgroundColor="#1AFFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1AFFFFFF"
                    app:strokeWidth="1dp">

                    <EditText
                        android:id="@+id/skin_url_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="https://minotar.net/skin/Steve"
                        android:inputType="textUri"
                        android:paddingHorizontal="16dp"
                        android:textColor="#E8EAF6"
                        android:textColorHint="#4D78909C"
                        android:textSize="13sp" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Update URL Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_update_url"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.1"
                    android:text="Update Skin URL"
                    android:textColor="#1A1B2E"
                    android:textStyle="bold"
                    app:backgroundTint="#FFB74D"
                    app:cornerRadius="14dp" />

                <!-- Upload from phone -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload_file"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="📁  Upload from Phone"
                    android:textColor="#9FA8DA"
                    android:textSize="13sp"
                    app:cornerRadius="14dp"
                    app:strokeColor="#225C6BC0"
                    app:strokeWidth="1dp" />

                <!-- OR Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#15FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="OR"
                        android:textColor="#4D78909C"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#15FFFFFF" />

                </LinearLayout>

                <!-- ===== MC PLAYER COPY ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.1"
                    android:text="COPY FROM MC PLAYER"
                    android:textColor="#78909C"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    app:cardBackgroundColor="#1AFFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1AFFFFFF"
                    app:strokeWidth="1dp">

                    <EditText
                        android:id="@+id/mc_username_input"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Minecraft username"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="#E8EAF6"
                        android:textColorHint="#4D78909C"
                        android:textSize="14sp" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_skin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Copy Player Skin"
                    android:textColor="#9FA8DA"
                    app:cornerRadius="14dp"
                    app:strokeColor="#225C6BC0"
                    app:strokeWidth="1dp" />

                <!-- ===== DEFAULT SKINS ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.1"
                    android:text="DEFAULT SKINS"
                    android:textColor="#78909C"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Steve -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_default_steve"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="🧱 Steve"
                        android:textColor="#66BB6A"
                        app:cornerRadius="12dp"
                        app:strokeColor="#2266BB6A"
                        app:strokeWidth="1dp" />

                    <!-- Alex -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_default_alex"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="🌸 Alex"
                        android:textColor="#AB47BC"
                        app:cornerRadius="12dp"
                        app:strokeColor="#22AB47BC"
                        app:strokeWidth="1dp" />

                </LinearLayout>

                <!-- ===== LOADING ===== -->
                <ProgressBar
                    android:id="@+id/loading_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="#FFB74D"
                    android:visibility="gone" />

                <!-- ===== MESSAGE ===== -->
                <TextView
                    android:id="@+id/skin_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>