<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1B2E"> <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <com.tungsten.fcllibrary.component.view.FCLLinearLayout
                android:id="@+id/special_setting_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="#F21A1B2E" 
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <com.tungsten.fcllibrary.component.view.FCLSwitch
                    android:id="@+id/enable_per_instance_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#FFB74D"
                    android:text="@string/settings_type_special_enable" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22FFFFFF" /> <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <com.tungsten.fcllibrary.component.view.FCLTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:singleLine="true"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_icon" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <com.tungsten.fcllibrary.component.view.FCLImageView
                        android:id="@+id/icon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/img_grass" />

                    <com.tungsten.fcllibrary.component.view.FCLImageButton
                        android:id="@+id/edit_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="15dp"
                        android:src="@drawable/ic_baseline_edit_24"
                        android:tint="#FFB74D"
                        app:no_padding="true" />

                    <com.tungsten.fcllibrary.component.view.FCLImageButton
                        android:id="@+id/delete_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="15dp"
                        android:src="@drawable/ic_baseline_close_24"
                        android:tint="#FFB74D"
                        app:no_padding="true" />

                </androidx.appcompat.widget.LinearLayoutCompat>

            </com.tungsten.fcllibrary.component.view.FCLLinearLayout>

            <com.tungsten.fcllibrary.component.view.FCLLinearLayout
                android:id="@+id/setting_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.tungsten.fcllibrary.component.view.FCLLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F21A1B2E"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_game_java_version" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/java"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#E8EAF6" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/edit_java"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_settings_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/install_java"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_download_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/edit_game_dir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_game_working_directory" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="15dp"
                        android:paddingBottom="15dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_memory" />

                        <com.tungsten.fcllibrary.component.view.FCLCheckBox
                            android:id="@+id/edit_auto_allocate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="#E8EAF6"
                            android:text="@string/settings_memory_auto_allocate" />

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="horizontal">

                            <com.tungsten.fcllibrary.component.view.FCLTextView
                                android:id="@+id/memory_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:singleLine="true"
                                android:textColor="#FFB74D"
                                android:text="@string/settings_memory_lower_bound" />

                            <com.tungsten.fcllibrary.component.view.FCLNumberSeekBar
                                android:id="@+id/edit_memory"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                app:suffix="MB" />

                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <com.tungsten.fcllibrary.component.view.FCLProgressBar
                            android:id="@+id/memory_bar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="5dp" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/memory_info_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:singleLine="true"
                            android:textColor="#E8EAF6"
                            android:text="@string/settings_memory_used_per_total" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/memory_allocate_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="5dp"
                            android:singleLine="true"
                            android:textColor="#E8EAF6"
                            android:text="@string/settings_memory_allocate_auto" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_advanced_server_ip" />

                        <com.tungsten.fcllibrary.component.view.FCLEditText
                            android:id="@+id/edit_server"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:hint="@string/settings_advanced_server_ip_prompt"
                            android:textColorHint="#88E8EAF6"
                            android:textColor="#E8EAF6"
                            android:singleLine="true"
                            android:textSize="14sp" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </com.tungsten.fcllibrary.component.view.FCLLinearLayout>

                <com.tungsten.fcllibrary.component.view.FCLLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#F21A1B2E"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_fcl_controller" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/controller"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#E8EAF6" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/edit_controller"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_settings_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/install_controller"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_download_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/edit_controller_injector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_fcl_controller_injector" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/use_opengl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_fcl_use_opengl" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_fcl_renderer" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/renderer"
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:textColor="#E8EAF6" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/edit_renderer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_settings_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/install_renderer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_download_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/pojav_big_core"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_fcl_pojav_bigcore" />
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/vulkan_driver_system"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_fcl_vulkan_driver_system" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/driver_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_fcl_driver" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/driver"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#E8EAF6" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/edit_driver"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_settings_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                        <com.tungsten.fcllibrary.component.view.FCLImageButton
                            android:id="@+id/install_driver"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_baseline_download_24"
                            android:tint="#FFB74D"
                            app:no_padding="true" />

                    </androidx.appcompat.widget.LinearLayoutCompat>


                </com.tungsten.fcllibrary.component.view.FCLLinearLayout>

                <com.tungsten.fcllibrary.component.view.FCLLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#F21A1B2E"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/edit_not_check_game"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_advanced_dont_check_game_completeness" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/edit_not_check_java"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_advanced_dont_check_jvm_validity" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/not_check_mod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_advanced_dont_check_mod" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/debug_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_advanced_debug_log" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_advanced_minecraft_arguments" />

                        <com.tungsten.fcllibrary.component.view.FCLEditText
                            android:id="@+id/edit_minecraft_args"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:hint="@string/settings_advanced_minecraft_arguments_prompt"
                            android:textColorHint="#88E8EAF6"
                            android:textColor="#E8EAF6"
                            android:singleLine="true"
                            android:textSize="14sp" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_advanced_jvm_args" />

                        <com.tungsten.fcllibrary.component.view.FCLEditText
                            android:id="@+id/edit_jvm_args"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:singleLine="true"
                            android:textColor="#E8EAF6"
                            android:textColorHint="#88E8EAF6"
                            android:textSize="14sp" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:textColor="#FFB74D"
                            android:text="@string/settings_advanced_custom_uuid" />

                        <com.tungsten.fcllibrary.component.view.FCLEditText
                            android:id="@+id/edit_uuid"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1"
                            android:singleLine="true"
                            android:textColor="#E8EAF6"
                            android:textColorHint="#88E8EAF6"
                            android:textSize="14sp" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <com.tungsten.fcllibrary.component.view.FCLSwitch
                        android:id="@+id/force_resolution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#FFB74D"
                        android:text="@string/settings_advanced_force_resolution" />

