<?xml version="1.0" encoding="utf-8"?>
<com.tungsten.fcllibrary.component.view.FCLUILayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/uiLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B">

    <!-- Live video background (GONE unless video file exists) -->
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Static/GIF/Image background -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dark overlay for readability -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#88000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TextureView for screen size detection (invisible) -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ===================== LEFT SIDEBAR ===================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/leftMenu"
        android:layout_width="72dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="#161616"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Account Avatar -->
            <com.tungsten.fcllibrary.component.view.FCLImageView
                android:id="@+id/avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_bg"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="4dp"/>

            <!-- Account Name -->
            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/accountName"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"/>

            <!-- Account Hint -->
            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/accountHint"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="7sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="8dp"/>

            <!-- Account click area -->
            <View
                android:id="@+id/account"
                android:layout_width="64dp"
                android:layout_height="0dp"
                android:layout_weight="0"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp"/>

            <!-- Divider -->
            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:background="#2A2A2A"
                android:layout_marginBottom="8dp"/>

            <!-- Home -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/home"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Manage -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/manage"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Download -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/download"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Controller -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/controller"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Multiplayer -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/multiplayer"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Setting -->
            <com.tungsten.fcllibrary.component.view.FCLMenuView
                android:id="@+id/setting"
                android:layout_width="56dp"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"/>

            <!-- Spacer -->
            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Back -->
            <androidx.cardview.widget.CardView
                android:id="@+id/back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===================== RIGHT PANEL ===================== -->
    <LinearLayout
        android:id="@+id/rightMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/leftMenu"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ===== TOP HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <!-- Title -->
            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"/>

            <!-- Start (top-right icon button) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/start"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginEnd="8dp"/>

            <!-- Jar executor button -->
            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/jar"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <!-- Version text button -->
            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/version"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ===== MAIN CONTENT (UIManager container) ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- ===== BOTTOM: VERSION INFO + PLAY BUTTON ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Version Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/versionInfoCard"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <!-- Version icon -->
                    <ImageView
                        android:id="@+id/icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Version name -->
                        <com.tungsten.fcllibrary.component.view.FCLTextView
                            android:id="@+id/versionName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="marquee"/>

                        <!-- Version progress bar -->
                        <ProgressBar
                            android:id="@+id/versionProgress"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:indeterminate="true"
                            android:visibility="gone"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Play Button Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/playButtonCard"
                android:layout_width="160dp"
                android:layout_height="58dp"
                app:cardBackgroundColor="#00E5FF"
                app:cardCornerRadius="6dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_play_block"
                        android:tint="#0B0B0B"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLAY"
                        android:textColor="#0B0B0B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-condensed"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>

</com.tungsten.fcllibrary.component.view.FCLUILayout>
