<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1B2E"
    android:padding="20dp">

    <!-- Title -->
    <com.tungsten.fcllibrary.component.view.FCLTextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/game_menu_settings"
        android:textColor="#FFB74D"
        android:textSize="18sp"
        android:textStyle="bold"
        android:singleLine="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title Divider -->
    <View
        android:id="@+id/title_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#22FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Slide Selection Switch -->
    <com.tungsten.fcllibrary.component.view.FCLSwitch
        android:id="@+id/slide_selection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/slide_selection"
        android:textColor="#E8EAF6"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/title_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Switch Divider -->
    <View
        android:id="@+id/switch_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#11FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/slide_selection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Swap Hands Switch -->
    <com.tungsten.fcllibrary.component.view.FCLSwitch
        android:id="@+id/swap_hands"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/swap_hands"
        android:textColor="#E8EAF6"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/switch_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Button Divider -->
    <View
        android:id="@+id/button_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#22FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/swap_hands"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Close Button -->
    <com.tungsten.fcllibrary.component.view.FCLButton
        android:id="@+id/btn_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/close"
        android:textAllCaps="false"
        android:textColor="#EF5350"
        app:layout_constraintTop_toBottomOf="@id/button_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
